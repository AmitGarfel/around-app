<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- רקע קרם עדין במקום לבן צורח -->
    <solid android:color="#F6F3EE" />

    <!-- מסגרת צהובה חמה יותר וברורה -->
    <stroke
        android:width="2dp"
        android:color="#E6C76A" />

    <!-- פינות יותר עגולות כדי להתאים ל-Card -->
    <corners android:radius="16dp" />

    <!-- ריווח פנימי קצת יותר מאוורר -->
    <padding
        android:left="14dp"
        android:top="10dp"
        android:right="14dp"
        android:bottom="10dp" />

</shape>

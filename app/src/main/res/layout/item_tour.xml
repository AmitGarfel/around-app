<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="10dp"
    app:cardCornerRadius="22dp"
    app:cardElevation="8dp"
    app:cardBackgroundColor="#FFFFFF"
    app:strokeColor="#E6C76A"
    app:strokeWidth="1dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/imageCard"
            android:layout_width="92dp"
            android:layout_height="62dp"
            android:layout_alignParentEnd="true"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <ImageView
                android:id="@+id/tourImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_launcher_background"
                android:contentDescription="@null"/>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:id="@+id/likeRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_marginTop="2dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/btnLike"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/heart_outline"
                android:contentDescription="Like"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/likesCountTv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="0"
                android:textColor="#2D2321"
                android:textStyle="bold"
                android:textSize="14sp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tourNameTv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toStartOf="@id/imageCard"
            android:layout_below="@id/likeRow"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="8dp"
            android:text="Levinsky Market Tasting Tour"
            android:textColor="#2D2321"
            android:textStyle="bold"
            android:textSize="16sp"
            android:maxLines="2"
            android:ellipsize="none" /> <TextView
        android:id="@+id/tourDetailsTv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_toStartOf="@id/imageCard"
        android:layout_below="@id/tourNameTv"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="4dp"
        android:text="1.5 hours • 3 stations"
        android:textColor="#6B5B56"
        android:textSize="13sp"
        android:maxLines="2"
        android:ellipsize="none" />

        <TextView
            android:id="@+id/btnView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_below="@id/tourDetailsTv"
            android:layout_marginTop="10dp"
            android:text="view"
            android:textAllCaps="false"
            android:textColor="#2D2321"
            android:textStyle="bold"
            android:textSize="12sp"
            android:paddingHorizontal="14dp"
            android:paddingVertical="7dp"
            android:background="@drawable/bg_view_pill"
            android:clickable="true"
            android:focusable="true" />

    </RelativeLayout>

</com.google.android.material.card.MaterialCardView>
<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layoutDirection="ltr">

    <ImageView
        android:id="@+id/ivHomeBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/city_bg" />

    <ScrollView
        android:id="@+id/homeScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottom_navigation"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingBottom="20dp"
            android:layoutDirection="ltr">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:gravity="left"
                android:orientation="vertical"
                android:padding="24dp"
                android:layoutDirection="ltr">

                <TextView
                    android:id="@+id/tvGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Good evening 🌙"
                    android:textColor="#FFFFFF"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:layoutDirection="ltr"
                    android:textDirection="ltr" />

                <TextView
                    android:id="@+id/tvSubGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Ready for your next route?"
                    android:textColor="#EDE7DD"
                    android:textSize="14sp"
                    android:layoutDirection="ltr"
                    android:textDirection="ltr" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="24dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="24dp"
                app:cardElevation="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="22dp"
                    android:layoutDirection="ltr">

                    <TextView
                        android:id="@+id/tvVibeHint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginBottom="8dp"
                        android:text="Change time, change vibe"
                        android:textColor="#7A6A5E"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layoutDirection="ltr"
                        android:textDirection="ltr" />

                    <Spinner
                        android:id="@+id/spinnerTimeOverride"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="2dp"
                        android:background="@drawable/spinner_bg_light"
                        android:entries="@array/time_options"
                        android:paddingHorizontal="14dp"
                        android:popupBackground="#FFFFFF"
                        android:layoutDirection="ltr" />

                    <TextView
                        android:id="@+id/tvCityHint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="14dp"
                        android:layout_marginBottom="8dp"
                        android:text="Explore another city"
                        android:textColor="#7A6A5E"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layoutDirection="ltr"
                        android:textDirection="ltr" />

                    <Spinner
                        android:id="@+id/spinnerCityOverride"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/spinner_bg_light"
                        android:paddingHorizontal="14dp"
                        android:popupBackground="#FFFFFF"
                        android:layoutDirection="ltr" />

                    <GridLayout
                        android:id="@+id/moodGrid"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:alignmentMode="alignMargins"
                        android:columnCount="2"
                        android:layoutDirection="ltr">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_margin="8dp"
                            app:cardBackgroundColor="#F6F3EE"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="3dp"
                            app:strokeColor="#E6C76A"
                            app:strokeWidth="1dp">

                            <LinearLayout
                                android:id="@+id/moodCulture"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:clickable="true"
                                android:focusable="true"
                                android:foreground="?attr/selectableItemBackground"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="18dp"
                                android:layoutDirection="ltr">

                                <androidx.appcompat.widget.AppCompatImageView
                                    android:layout_width="70dp"
                                    android:layout_height="70dp"
                                    android:background="@drawable/rounded_yellow_bg"
                                    android:padding="18dp"
                                    android:src="@drawable/ic_culture"
                                    app:tint="#2D2321" />

                                <com.google.android.material.textview.MaterialTextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="10dp"
                                    android:text="culture"
                                    android:textColor="#2D2321"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_margin="8dp"
                            app:cardBackgroundColor="#F6F3EE"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="3dp"
                            app:strokeColor="#E6C76A"
                            app:strokeWidth="1dp">

                            <LinearLayout
                                android:id="@+id/moodFoody"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:clickable="true"
                                android:focusable="true"
                                android:foreground="?attr/selectableItemBackground"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="18dp"
                                android:layoutDirection="ltr">

                                <androidx.appcompat.widget.AppCompatImageView
                                    android:layout_width="70dp"
                                    android:layout_height="70dp"
                                    android:background="@drawable/rounded_yellow_bg"
                                    android:padding="18dp"
                                    android:src="@drawable/ic_foody"
                                    app:tint="#2D2321" />

                                <com.google.android.material.textview.MaterialTextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="10dp"
                                    android:text="foody"
                                    android:textColor="#2D2321"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_margin="8dp"
                            app:cardBackgroundColor="#F6F3EE"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="3dp"
                            app:strokeColor="#E6C76A"
                            app:strokeWidth="1dp">

                            <LinearLayout
                                android:id="@+id/moodSurprise"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:clickable="true"
                                android:focusable="true"
                                android:foreground="?attr/selectableItemBackground"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="18dp"
                                android:layoutDirection="ltr">

                                <androidx.appcompat.widget.AppCompatImageView
                                    android:layout_width="70dp"
                                    android:layout_height="70dp"
                                    android:background="@drawable/rounded_yellow_bg"
                                    android:padding="18dp"
                                    android:src="@drawable/ic_surprise"
                                    app:tint="#2D2321" />

                                <com.google.android.material.textview.MaterialTextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="10dp"
                                    android:text="surprise me"
                                    android:textColor="#2D2321"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_margin="8dp"
                            app:cardBackgroundColor="#F6F3EE"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="3dp"
                            app:strokeColor="#E6C76A"
                            app:strokeWidth="1dp">

                            <LinearLayout
                                android:id="@+id/moodRelax"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:clickable="true"
                                android:focusable="true"
                                android:foreground="?attr/selectableItemBackground"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="18dp"
                                android:layoutDirection="ltr">

                                <androidx.appcompat.widget.AppCompatImageView
                                    android:layout_width="70dp"
                                    android:layout_height="70dp"
                                    android:background="@drawable/rounded_yellow_bg"
                                    android:padding="18dp"
                                    android:src="@drawable/ic_spa"
                                    app:tint="#2D2321" />

                                <com.google.android.material.textview.MaterialTextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="10dp"
                                    android:text="relax"
                                    android:textColor="#2D2321"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                    </GridLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF"
        android:layoutDirection="ltr"
        android:textDirection="ltr"
        app:itemIconTint="@color/bottom_nav_item_colors"
        app:itemTextColor="@color/bottom_nav_item_colors"
        app:labelVisibilityMode="labeled"
        app:itemHorizontalTranslationEnabled="false"
        app:menu="@menu/bottom_nav_menu" />

</RelativeLayout>
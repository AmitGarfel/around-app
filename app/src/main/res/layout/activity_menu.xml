<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Background -->
    <ImageView
        android:id="@+id/ivBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/city_bg"
        android:scaleType="centerCrop"
        android:contentDescription="@null" />

    <!-- Overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#5E000000" />

    <!-- Main content -->
    <LinearLayout
        android:id="@+id/menuMainLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:animateLayoutChanges="true"
        android:paddingHorizontal="20dp">

        <!-- Logo -->
        <TextView
            android:id="@+id/tvAppTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="72dp"
            android:text="AROUND"
            android:textColor="#2D2321"
            android:textSize="26sp"
            android:textStyle="bold"
            android:background="@drawable/rounded_yellow_bg"
            android:paddingHorizontal="34dp"
            android:paddingVertical="12dp" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="34dp"
            android:text="Start your next city experience"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:alpha="0.85" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Choose your next step"
            android:textColor="#FFFFFF"
            android:textSize="30sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp" />

        <!-- Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="34dp"
            android:layout_marginHorizontal="8dp"
            app:cardCornerRadius="30dp"
            app:cardElevation="16dp"
            app:cardBackgroundColor="#FDFDFD">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Regular user -->
                <LinearLayout
                    android:id="@+id/layoutRegularActions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:visibility="gone">

                    <!-- Explore -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageButton
                            android:id="@+id/btnExploreRegular"
                            android:layout_width="82dp"
                            android:layout_height="82dp"
                            android:background="@drawable/rounded_yellow_bg"
                            android:padding="20dp"
                            android:src="@android:drawable/ic_menu_search"
                            android:contentDescription="Explore"
                            app:tint="#2D2321" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Explore"
                            android:textColor="#2D2321"
                            android:textStyle="bold"
                            android:textSize="17sp" />
                    </LinearLayout>

                    <Space
                        android:layout_width="28dp"
                        android:layout_height="1dp" />

                    <!-- Create -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageButton
                            android:id="@+id/btnCreateRegular"
                            android:layout_width="82dp"
                            android:layout_height="82dp"
                            android:background="@drawable/rounded_yellow_bg"
                            android:padding="20dp"
                            android:src="@android:drawable/ic_menu_edit"
                            android:contentDescription="Create"
                            app:tint="#2D2321" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Create"
                            android:textColor="#2D2321"
                            android:textStyle="bold"
                            android:textSize="17sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Admin -->
                <LinearLayout
                    android:id="@+id/layoutAdminActions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="3"
                    android:visibility="gone">

                    <!-- Explore -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageButton
                            android:id="@+id/btnExploreAdmin"
                            android:layout_width="74dp"
                            android:layout_height="74dp"
                            android:background="@drawable/rounded_yellow_bg"
                            android:padding="18dp"
                            android:src="@android:drawable/ic_menu_search"
                            android:contentDescription="Explore"
                            app:tint="#2D2321" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Explore"
                            android:textColor="#2D2321"
                            android:textStyle="bold"
                            android:layout_marginTop="10dp" />
                    </LinearLayout>

                    <!-- Create -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageButton
                            android:id="@+id/btnCreateAdmin"
                            android:layout_width="74dp"
                            android:layout_height="74dp"
                            android:background="@drawable/rounded_yellow_bg"
                            android:padding="18dp"
                            android:src="@android:drawable/ic_menu_edit"
                            android:contentDescription="Create"
                            app:tint="#2D2321" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Create"
                            android:textColor="#2D2321"
                            android:textStyle="bold"
                            android:layout_marginTop="10dp" />
                    </LinearLayout>

                    <!-- Admin -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageButton
                            android:id="@+id/btnAdmin"
                            android:layout_width="74dp"
                            android:layout_height="74dp"
                            android:background="@drawable/rounded_yellow_bg"
                            android:padding="18dp"
                            android:src="@android:drawable/ic_lock_idle_lock"
                            android:contentDescription="Admin"
                            app:tint="#2D2321" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Admin"
                            android:textColor="#2D2321"
                            android:textStyle="bold"
                            android:layout_marginTop="10dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Recommended -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="30dp"
                    android:text="Recommended for you"
                    android:textColor="#7A5901"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/rounded_yellow_bg"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="14dp">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_location_pin"
                        android:contentDescription="@null"
                        app:tint="#5D4300" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvQuickInfo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Explore tours near you"
                            android:textColor="#5D4300"
                            android:textStyle="bold"
                            android:textSize="16sp" />

                        <TextView
                            android:id="@+id/tvQuickInfoSub"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Based on your current location"
                            android:textColor="#7A5901"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- Bottom nav -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF"
        app:itemIconTint="@color/bottom_nav_item_colors"
        app:itemTextColor="@color/bottom_nav_item_colors"
        app:menu="@menu/bottom_nav_menu" />

</RelativeLayout>
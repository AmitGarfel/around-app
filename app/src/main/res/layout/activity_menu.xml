<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layoutDirection="ltr">

    <ImageView
        android:id="@+id/ivBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/city_bg"
        android:scaleType="centerCrop"
        android:contentDescription="@null" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#5E000000" />

    <LinearLayout
        android:id="@+id/menuMainLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:animateLayoutChanges="true"
        android:paddingHorizontal="20dp"
        android:layoutDirection="ltr">

        <TextView
            android:id="@+id/tvAppTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="72dp"
            android:text="AROUND"
            android:textColor="#2D2321"
            android:textSize="26sp"
            android:textStyle="bold"
            android:background="@drawable/rounded_yellow_bg"
            android:paddingHorizontal="34dp"
            android:paddingVertical="12dp"
            android:layoutDirection="ltr"
            android:textDirection="ltr" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="34dp"
            android:text="Start your next city experience"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:alpha="0.85"
            android:layoutDirection="ltr"
            android:textDirection="ltr" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Choose your next step"
            android:textColor="#FFFFFF"
            android:textSize="30sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:layoutDirection="ltr"
            android:textDirection="ltr" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="34dp"
            android:layout_marginHorizontal="8dp"
            app:cardCornerRadius="30dp"
            app:cardElevation="16dp"
            app:cardBackgroundColor="#FDFDFD">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:layoutDirection="ltr">

                <LinearLayout
                    android:id="@+id/layoutRegularActions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:visibility="gone"
                    android:layoutDirection="ltr">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:layoutDirection="ltr">

                        <ImageButton
                            android:id="@+id/btnExploreRegular"
                            android:layout_width="82dp"
                            android:layout_height="82dp"
                            android:background="@drawable/rounded_yellow_bg"
                            android:padding="20dp"
                            android:src="@android:drawable/ic_menu_search"
                            android:contentDescription="Explore"
                            app:tint="#2D2321" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Explore"
                            android:textColor="#2D2321"
                            android:textStyle="bold"
                            android:textSize="17sp" />
                    </LinearLayout>

                    <Space
                        android:layout_width="28dp"
                        android:layout_height="1dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:layoutDirection="ltr">

                        <ImageButton
                            android:id="@+id/btnCreateRegular"
                            android:layout_width="82dp"
                            android:layout_height="82dp"
                            android:background="@drawable/rounded_yellow_bg"
                            android:padding="20dp"
                            android:src="@android:drawable/ic_menu_edit"
                            android:contentDescription="Create"
                            app:tint="#2D2321" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Create"
                            android:textColor="#2D2321"
                            android:textStyle="bold"
                            android:textSize="17sp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layoutAdminActions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="3"
                    android:visibility="gone"
                    android:layoutDirection="ltr">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:layoutDirection="ltr">

                        <ImageButton
                            android:id="@+id/btnExploreAdmin"
                            android:layout_width="74dp"
                            android:layout_height="74dp"
                            android:background="@drawable/rounded_yellow_bg"
                            android:padding="18dp"
                            android:src="@android:drawable/ic_menu_search"
                            android:contentDescription="Explore"
                            app:tint="#2D2321" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Explore"
                            android:textColor="#2D2321"
                            android:textStyle="bold"
                            android:layout_marginTop="10dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:layoutDirection="ltr">

                        <ImageButton
                            android:id="@+id/btnCreateAdmin"
                            android:layout_width="74dp"
                            android:layout_height="74dp"
                            android:background="@drawable/rounded_yellow_bg"
                            android:padding="18dp"
                            android:src="@android:drawable/ic_menu_edit"
                            android:contentDescription="Create"
                            app:tint="#2D2321" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Create"
                            android:textColor="#2D2321"
                            android:textStyle="bold"
                            android:layout_marginTop="10dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:layoutDirection="ltr">

                        <ImageButton
                            android:id="@+id/btnAdmin"
                            android:layout_width="74dp"
                            android:layout_height="74dp"
                            android:background="@drawable/rounded_yellow_bg"
                            android:padding="18dp"
                            android:src="@android:drawable/ic_lock_idle_lock"
                            android:contentDescription="Admin"
                            app:tint="#2D2321" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Admin"
                            android:textColor="#2D2321"
                            android:textStyle="bold"
                            android:layout_marginTop="10dp" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="30dp"
                    android:text="Recommended for you"
                    android:textColor="#7A5901"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:gravity="left"
                    android:textAlignment="gravity"
                    android:layoutDirection="ltr"
                    android:textDirection="ltr" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/rounded_yellow_bg"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="14dp"
                    android:layoutDirection="ltr">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_location_pin"
                        android:contentDescription="@null"
                        app:tint="#5D4300" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:orientation="vertical"
                        android:layoutDirection="ltr">

                        <TextView
                            android:id="@+id/tvQuickInfo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Near you: Hod Hasharon Tours"
                            android:textColor="#5D4300"
                            android:textStyle="bold"
                            android:textSize="15sp"
                            android:maxLines="1"
                            android:gravity="left"
                            android:textAlignment="gravity"
                            android:layoutDirection="ltr"
                            android:textDirection="ltr"
                            android:autoSizeTextType="uniform"
                            android:autoSizeMinTextSize="11sp"
                            android:autoSizeMaxTextSize="15sp"
                            android:autoSizeStepGranularity="1sp" />

                        <TextView
                            android:id="@+id/tvQuickInfoSub"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Based on your current location"
                            android:textColor="#555555"
                            android:textSize="14sp"
                            android:gravity="left"
                            android:textAlignment="gravity"
                            android:layoutDirection="ltr"
                            android:textDirection="ltr" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF"
        android:layoutDirection="ltr"
        android:textDirection="ltr"
        app:itemIconTint="@color/bottom_nav_item_colors"
        app:itemTextColor="@color/bottom_nav_item_colors"
        app:labelVisibilityMode="labeled"
        app:itemHorizontalTranslationEnabled="false"
        app:menu="@menu/bottom_nav_menu" />

</RelativeLayout>
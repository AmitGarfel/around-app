<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="20dp"
    app:cardCornerRadius="24dp"
    app:cardBackgroundColor="#D7D2CB"
    app:strokeColor="#FFC107"
    app:strokeWidth="3dp"
    app:cardElevation="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_horizontal">

        <TextView
            android:id="@+id/tvTourDetailName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/rounded_yellow_bg"
            android:paddingHorizontal="24dp"
            android:paddingVertical="8dp"
            android:text="Tour name"
            android:textColor="#2D2321"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_marginBottom="16dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="160dp"
            android:layout_height="160dp"
            app:cardCornerRadius="20dp"
            android:layout_marginBottom="16dp">

            <ImageView
                android:id="@+id/ivTourDetailImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_launcher_background" />
        </com.google.android.material.card.MaterialCardView>

        <!-- ✅ Blue box contains BOTH description + stations -->
        <LinearLayout
            android:id="@+id/blueBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_details_blue"
            android:padding="16dp"
            android:layoutDirection="ltr">

            <TextView
                android:id="@+id/tvTourDetailDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tour description..."
                android:textColor="#2D2321"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp"
                android:layoutDirection="ltr"
                android:gravity="left"
                android:textAlignment="viewStart" />

            <View
                android:layout_width="match_parent"
                android:layout_height="10dp"/>

            <!-- ✅ stations list container (forced LEFT) -->
            <LinearLayout
                android:id="@+id/llStationsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layoutDirection="ltr"
                android:gravity="left"
                android:layout_gravity="left"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp"
            android:weightSum="2">

            <Button
                android:id="@+id/btnNotNow"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="not now"
                android:textAllCaps="false"
                android:backgroundTint="#FFC107"
                android:textColor="#2D2321"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnLetsGo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Let's go"
                android:textAllCaps="false"
                android:backgroundTint="#FFC107"
                android:textColor="#2D2321" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
